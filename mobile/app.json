{
  "expo": {
    "name": "MeetDewan",
    "slug": "meetdewan",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "scheme": "meetdewan",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "id.go.jabar.dprd.meetdewan",
      "infoPlist": {
        "NSCameraUsageDescription": "Aplikasi memerlukan akses kamera untuk pertemuan video dengan anggota dewan.",
        "NSMicrophoneUsageDescription": "Aplikasi memerlukan akses mikrofon untuk pertemuan audio dengan anggota dewan."
      }
    },
    "android": {
      "package": "id.go.jabar.dprd.meetdewan",
      "adaptiveIcon": {
        "backgroundColor": "#D4AF37",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.INTERNET",
        "android.permission.ACCESS_NETWORK_STATE",
        "android.permission.BLUETOOTH",
        "android.permission.BLUETOOTH_CONNECT"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-font",
      "@livekit/react-native-expo-plugin",
      "@config-plugins/react-native-webrtc",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#0F0F12",
          "image": "./assets/splash-icon.png",
          "imageWidth": 120
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}

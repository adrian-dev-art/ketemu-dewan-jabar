generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           Int            @id @default(autoincrement())
  name         String
  email        String         @unique
  role         String         // 'admin', 'dewan', 'masyarakat'
  passwordHash String?        // Nullable for now to support existing seeded users
  bio          String?
  schedulesAsDewan      Schedule[]     @relation("DewanSchedules")
  schedulesAsMasyarakat Schedule[]     @relation("MasyarakatSchedules")
  ratingsAsDewan        Rating[]       @relation("DewanRatings")
  availabilities        Availability[] @relation("DewanAvailability")
}

model Availability {
  id        Int      @id @default(autoincrement())
  startTime DateTime
  endTime   DateTime
  dewanId   Int
  dewan     User     @relation("DewanAvailability", fields: [dewanId], references: [id])
}

model Schedule {
  id           Int      @id @default(autoincrement())
  title        String   @default("Diskusi Aspirasi")
  startTime    DateTime
  status       String   @default("pending") // 'pending', 'confirmed', 'rejected'
  
  dewanId      Int
  dewan        User     @relation("DewanSchedules", fields: [dewanId], references: [id])
  
  masyarakatId Int
  masyarakat   User     @relation("MasyarakatSchedules", fields: [masyarakatId], references: [id])
  
  rating       Rating?
}

model Rating {
  id            Int      @id @default(autoincrement())
  speakingScore Int
  contextScore  Int
  timeScore     Int
  comment       String?
  
  scheduleId Int      @unique
  schedule   Schedule @relation(fields: [scheduleId], references: [id])
  
  dewanId    Int
  dewan      User     @relation("DewanRatings", fields: [dewanId], references: [id])
}

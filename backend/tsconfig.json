{
  "compilerOptions": {
    "target": "es2016",
    "module": "commonjs",
    "rootDir": "./src",
    "outDir": "./dist",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true
  },
  "exclude": [
    "node_modules",
    "prisma",
    "dist",
    "seed_asep.ts",
    "fix_db.ts",
    "src/fix_db.ts",
    "src/debug_upsert.js",
    "src/fix_db.js",
    "check-room.ts",
    "test-stream.ts",
    "scratch/**/*",
    "src/services/__tests__/**/*"
  ]
}
# Database Configuration
DB_USER=meetdewan_user
DB_PASSWORD=your_secure_password
DB_NAME=meetdewan_db

# Backend Configuration
PORT=5000
FRONTEND_URL=http://your-domain.com:3001

# Frontend Configuration
# FRONTEND_URL=http://localhost:3000
NEXT_PUBLIC_BACKEND_URL=http://localhost:5000

# WebRTC STUN/TURN configuration
# STUN: Comma separated list of stun urls
NEXT_PUBLIC_STUN_SERVERS=stun:stun.l.google.com:19302,stun:stun1.l.google.com:19302
# TURN: Comma separated list of turn urls. Provide username and password if required.
NEXT_PUBLIC_TURN_SERVERS=
NEXT_PUBLIC_TURN_USERNAME=
NEXT_PUBLIC_TURN_PASSWORD=
